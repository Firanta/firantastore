rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return request.auth.token.isAdmin == true;
    }
    
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    
    // Admin documents - own document is readable
    match /admins/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow write: if isOwner(uid) && isAdmin();
    }
    
    // Orders collection - users can read own, admin can manage all
    match /orders/{orderId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // Templates - public read, admin write
    match /templates/{templateId} {
      allow read: if true; // Public - allow anyone
      allow create, update, delete: if isAdmin();
    }
    
    // Users - own document readable, admin can see all
    match /users/{uid} {
      allow read: if isSignedIn() && (isOwner(uid) || isAdmin());
      allow create, update: if isSignedIn() && isOwner(uid);
      allow delete: if isAdmin();
    }
    
    // Transactions - users can read own, admin can manage all
    match /transactions/{transId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Ratings - public read, users can write own
    match /ratings/{ratingId} {
      allow read: if true; // Public
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data.userId);
    }

    // Cart - user's own cart
    match /cart/{uid} {
      allow read, write: if isSignedIn() && isOwner(uid);
    }

    // Categories - public read, admin write
    match /categories/{catId} {
      allow read: if true; // Public
      allow write: if isAdmin();
    }

    // Catch-all - deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
