{
  "name": "firantastoree-functions",
  "description": "Firebase Cloud Functions for Firantastoree",
  "type": "commonjs",
  "scripts": {
    "lint": "eslint src",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run build:watch & firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "midtrans-client": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "eslint": "^8.0.0"
  }
}
